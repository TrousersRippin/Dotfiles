# Tmux
alias tmav='tmux attach -t vertical'
alias tmah='tmux attach -t horizontal'
alias tmd='tmux detach'
alias tmk='tmux kill-server'
alias tmnv='tmux new-session -s vertical \; split-window -h \; split-window -v \; attach'
alias tmnh='tmux new-session -s horizontal \; split-window -v \; split-window -h \; attach'
alias tml='tmux list-sessions'

# General
