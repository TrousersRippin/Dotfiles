-- Nicer prompt: user@db#
\set PROMPT1 '%n@%/%R%# '

-- Timing on by default
\timing

-- Expanded output when needed
\x auto

-- Null display (easier to spot)
\pset null '∅'

-- Better history
\set HISTSIZE 10000
\set HISTCONTROL ignoredups

-- Verbose error reports
\set VERBOSITY verbose

-- Handy shortcuts
\set version 'SELECT version();'
\set activity 'SELECT pid, usename, application_name, state, wait_event_type, wait_event, query_start, left(query,80) FROM pg_stat_activity WHERE state IS NOT NULL;'
